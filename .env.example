# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://127.0.0.1:5500

# ── Databases ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://your-neon-pooler-url/neondb?sslmode=require&pgbouncer=true&connection_limit=3&connect_timeout=30&pool_timeout=60&socket_timeout=60
DIRECT_URL=postgresql://your-neon-direct-url/neondb?sslmode=require
MONGO_URI=mongodb://your-mongo-atlas-uri


PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
SKRILL_MERCHANT_ID=YOUR_MERCHANT_ID
SKRILL_MERCHANT_EMAIL=your_skrill_merchant_email
SKRILL_SECRET_WORD=your_skrill_secret_word

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_64_char_secret_here
JWT_REFRESH_SECRET=your_64_char_secret_here
JWT_ACCESS_EXPIRES=25m
JWT_REFRESH_EXPIRES=7d
JWT_DOWNLOAD_SECRET=your_download_secret_here
COOKIE_SECRET=your_cookie_secret_here

# ── Redis (Upstash — free tier) ───────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token
REDIS_HOST=your-upstash-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_password
REDIS_TLS=true

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# ── Email (Brevo) ──────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
ADMIN_EMAIL=your_admin_notification_email

BACKEND_URL=https://detonate-trend-surcharge.ngrok-free.dev

# ── Commission rates ──────────────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.30
CREATOR_REVENUE_RATE=0.70
EARLY_ADOPTER_LIMIT=50
EARLY_ADOPTER_COMMISSION_RATE=0.10

# ── Admin info ────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=replace_with_strong_secret

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_AUTH_WINDOW_MS=300000
RATE_LIMIT_UPLOAD_MAX=40
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000
RATE_LIMIT_PAYMENT_MAX=50
RATE_LIMIT_PAYMENT_WINDOW_MS=900000

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

PAYMENTS_ENABLED=false

YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:5000/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_one_time_refresh_token

DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_WEBHOOK_GENERAL=...
DISCORD_WEBHOOK_CREATORS=...
DISCORD_WEBHOOK_CLIENTS=...
DISCORD_WEBHOOK_ANNOUNCE=...